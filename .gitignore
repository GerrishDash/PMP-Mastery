# Exclude all markdown files by default
*.md
!README.md

# Exclude actual PDF document files by default
*.pdf

# Allow book folders and their markdown/image contents
!*.pdf/
!**/*.pdf/
!**/*.pdf/**/*.md
!**/*.pdf/**/*.jpeg
!**/*.pdf/**/*.jpg
!**/*.pdf/**/*.png

# Exclude SSH Keys
Key1
Key1.pub
Key/

# Exclude dependencies and test files
node_modules/
test_click.js
